#!/usr/bin/env pwsh
$ErrorActionPreference = 'Stop'
Set-StrictMode -Version Latest

# Allow internal corrective pushes to bypass hook recursion.
if ($env:WCC_SKIP_PREPUSH -eq '1') {
    exit 0
}

$repoRoot = (& git rev-parse --show-toplevel).Trim()
Set-Location -LiteralPath $repoRoot

$remoteName = if ($args.Count -ge 1 -and -not [string]::IsNullOrWhiteSpace($args[0])) {
    $args[0]
} else {
    'origin'
}

$versionFile = '.wombat-cc-version'
if (-not (Test-Path -LiteralPath $versionFile)) {
    exit 0
}

$modifiedRefs = $false
$updatedTags = [System.Collections.Generic.List[string]]::new()
$deleteSha = '0000000000000000000000000000000000000000'
$stdin = [Console]::In

# Input lines are: <local_ref> <local_sha> <remote_ref> <remote_sha>
while (($line = $stdin.ReadLine()) -ne $null) {
    if ([string]::IsNullOrWhiteSpace($line)) {
        continue
    }

    $parts = $line -split '\s+'
    if ($parts.Count -lt 4) {
        continue
    }

    $localRef = $parts[0]
    $localSha = $parts[1]

    if (-not $localRef.StartsWith('refs/tags/v')) {
        continue
    }

    # Skip tag deletions.
    if ($localSha -eq $deleteSha) {
        continue
    }

    $tagName = $localRef.Substring('refs/tags/'.Length)
    $currentVersion = (Get-Content -LiteralPath $versionFile -Raw).Replace("`r", '').Replace("`n", '')
    if ($currentVersion -eq $tagName) {
        continue
    }

    Write-Host "pre-push: syncing $versionFile to $tagName"
    Set-Content -LiteralPath $versionFile -Value $tagName
    & git add -- $versionFile | Out-Null
    if ($LASTEXITCODE -ne 0) {
        throw 'pre-push: failed to stage version file update.'
    }

    & git diff --cached --quiet -- $versionFile
    $hasDiff = $LASTEXITCODE -ne 0

    if ($hasDiff) {
        & git -c commit.gpgsign=false commit --no-verify -m "chore: bump .wombat-cc-version to $tagName" | Out-Null
        if ($LASTEXITCODE -ne 0) {
            throw 'pre-push: failed to create version bump commit.'
        }
    }

    $newSha = (& git rev-parse HEAD).Trim()
    & git tag -f $tagName $newSha | Out-Null
    if ($LASTEXITCODE -ne 0) {
        throw "pre-push: failed to retarget local tag '$tagName'."
    }

    if (-not $updatedTags.Contains($tagName)) {
        $updatedTags.Add($tagName) | Out-Null
    }
    $modifiedRefs = $true
}

if ($modifiedRefs) {
    $branchName = (& git symbolic-ref --quiet --short HEAD 2>$null).Trim()

    # Push corrected refs directly and bypass hook recursion.
    if (-not [string]::IsNullOrWhiteSpace($branchName)) {
        & git push --no-verify $remoteName $branchName | Out-Null
        if ($LASTEXITCODE -ne 0) {
            throw "pre-push: failed to push branch '$branchName' to '$remoteName'."
        }
    }

    foreach ($tagName in $updatedTags) {
        & git push --no-verify --force-with-lease $remoteName "refs/tags/$tagName" | Out-Null
        if ($LASTEXITCODE -ne 0) {
            throw "pre-push: failed to push corrected tag '$tagName' to '$remoteName'."
        }
    }

    Write-Host 'pre-push: updated version marker and retargeted local tag(s).'
    Write-Host 'pre-push: pushed corrected refs automatically.'
    Write-Host 'pre-push: original push is cancelled intentionally; remote is already updated.'
    exit 1
}

exit 0
